# Telegram API
API_ID=你的API_ID
API_HASH=你的API_HASH

# Bot Token
BOT_TOKEN=你的Bot_Token

# 源群组ID（万国号铺订单群）
SOURCE_CHAT_ID=-1001234567890

# 目标频道ID（你的频道）
TARGET_CHANNEL_ID=-1009876543210

# ShopBot配置
SHOPBOT_USERNAME=YourShopBot
SHOPBOT_DB_PATH=E:/工具/shop/shopbot/shopbot-stable/shopbot.db

# 价格降级策略（匹配失败时加价）
FALLBACK_PRICE_INCREASE=0.2
